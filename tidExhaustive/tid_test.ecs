$Name5 = 0
$Name6 = 0
$Name7 = 0

# ==========================================
# 1. 【用户自定义区】 - 穷举搜索设置
# ==========================================
$每个点测试次数 = 0# 每个毫秒组合跑几次 (去噪)

# --- F3 搜索设置 (最内层，变化最快) ---
$F3步长 = 0# 每次增加多少 ms
$F3搜索范围 = 0# F3 增加到多少 ms 后归零并进位给 F2

# --- F2 搜索设置 (中层) ---
$F2步长 = 0# 每次增加多少 ms
$F2搜索范围 = 0# F2 增加到多少 ms 后归零并进位给 F1

# --- F1 搜索设置 (最外层) ---
$F1步长 = 0# 每次增加多少 ms

# --- 基础基准时间 (ms) ---
$SEED_TIME = 0
$F1_BASE = 0
$F2_BASE = 0
$F3_BASE = 0

$PARITY_TIME = 0





# ====================== 内部运行变量 ======================
# 以下为脚本内部使用变量，一般无需手动修改
$MAX_ADV = 2147483647

$CISHU = 0

$ID_POLL_DONE = 0

$Stop = 0

CALL 用户自定义配置

$seed = $TARGET_TID

$target1 = $TARGET_TID
$target1 /= 10000

$target2 = $TARGET_TID
$target2 /= 1000
$target2 %= 10

$target3 = $TARGET_TID
$target3 /= 100
$target3 %= 10

$target4 = $TARGET_TID
$target4 /= 10
$target4 %= 10

$target5 = $TARGET_TID
$target5 %= 10


#[23:02:33.809] OP目标偏移量(+ms):292ms
#[23:02:33.809] F1目标偏移量(+ms):368ms
#[23:02:33.809] F2目标偏移量(+ms):8134ms
#$OP脚本固定延迟 = 30550
#$F1脚本固定延迟 = 21490
#$F2脚本固定延迟 = 3891
#$F3脚本固定延迟 = 14892
#61798, 12846, 15410, 16797, 30256
# 固定动作参数

# ============================================================

# --- 变量初始化 ---
$F1_start = 0
$F2_start = 0
$F3_start = 0
$f_start = 0
$f_now = 0
$f_diff = 0
$delay_ms = 0
$error = 0
$t_elapsed = 0
# --- 高精度计时函数 ---
FUNC PreciseWait
    $f_start = TIME()
    FOR
        $f_now = TIME()
        $f_diff = $f_now - $f_start
        IF $f_diff >= $delay_ms
            BREAK
        ENDIF
    NEXT
    $error = $f_diff - $delay_ms
ENDFUNC




# ==========================================
# 2. 内部变量初始化
# ==========================================
$F1_Off = 0
$F2_Off = 0
$F3_Off = 0
$组内计数 = 0
$总运行轮数 = 0

# ==========================================
# 3. 主程序循环
# ==========================================
FOR
    # 计算本轮的实际目标时间轴
    $Target_F1 = $F1_BASE + $F1_Off
    $Target_F2 = $F2_BASE + $F2_Off
    $Target_F3 = $F3_BASE + $F3_Off
    
    $总运行轮数 += 1
    $组内计数 += 1
    
    PRINT ========================
    PRINT [总第 & $总运行轮数 & 轮]
    PRINT [当前参数] F1: & $Target_F1 & | F2: & $Target_F2 & | F3: & $Target_F3
    PRINT [组内进度] & $组内计数 & / & $每个点测试次数
    
    # --- 环境清理与启动 ---
    CALL 关闭软件
    WAIT 3000
    A# 重新进入游戏
    
    
    # --- 第一段：锁定 Seed (OP阶段) ---
    
    $delay_ms = $SEED_TIME
    CALL PreciseWait
    A DOWN
    WAIT 4000
    A UP
    
    # --- 第二段：锁定奇偶性 (存档界面) ---
    WAIT 500
    DOWN
    $delay_ms = $PARITY_TIME
    CALL PreciseWait
    A DOWN
    WAIT 4000
    A UP
    
    # 【进入游戏绝对原点】
    $F1_start = TIME()
    
    # --- 对齐 F1 ---
    WAIT 1500
    A
    WAIT 1000
    A
    WAIT 1000
    A
    WAIT 2500
    A
    WAIT 1000
    A
    WAIT 1000
    FOR
        $now = TIME()
        $elapsed = $now - $F1_start
        IF $elapsed >= $Target_F1
            BREAK
        ENDIF
    NEXT
    A DOWN
    WAIT 4000
    A UP
    
    # --- 对齐 F2 ---
    $F2_start = TIME()
    WAIT 1500
    B
    WAIT 1000
    B
    WAIT 500
    B
    WAIT 1000
    B
    WAIT 2000
    B
    WAIT 1500
    B
    WAIT 500
    B
    WAIT 1000
    B
    WAIT 3000
    B
    WAIT 3000
    DOWN
    WAIT 1000
    A
    FOR
        $now = TIME()
        $elapsed = $now - $F2_start
        IF $elapsed >= $Target_F2
            BREAK
        ENDIF
    NEXT
    A DOWN
    WAIT 4000
    A UP
    
    # --- 对齐 F3 (取名) ---
    $F3_start = TIME()
    CALL 取名
    
    FOR 5
        Y
        WAIT 500
    NEXT
    
    FOR
        $now = TIME()
        $elapsed = $now - $F3_start
        IF $elapsed >= $Target_F3
            BREAK
        ENDIF
    NEXT
    A
    3000
    # --- 后续进入 ID 卡查询 ---
    CALL idCheck
    
    
    
    $ID_POLL_DONE = 0
    FOR
        100#识图轮询间隔
        IF @IDNo >= 95
            500#等待ID卡加载
            
            CALL 处理ID检测
            IF $ID_POLL_DONE == 1
                IF $Stop == 1
                    BREAK
                ENDIF
                BREAK
            ENDIF
            
        ENDIF
        
    NEXT
    
    # ==========================================
    # 4. 三层进位进阶逻辑 (每行一条指令)
    # ==========================================
    
    # 检查是否完成了当前点的测试次数
    IF $组内计数 >= $每个点测试次数
        $组内计数 = 0
        # 开始增加 F3 (最内层)
        $F3_Off += $F3步长
        PRINT >>> F3 增加，进入下一毫秒测试 >>>
        
        # 检查 F3 是否超出了设定的搜索范围
        IF $F3_Off > $F3搜索范围
            $F3_Off = 0
            # F3 扫完一圈，进位给 F2
            $F2_Off += $F2步长
            PRINT >>> F3 归零，F2 进位增加 >>>
            
            # 检查 F2 是否超出了范围
            IF $F2_Off > $F2搜索范围
                $F2_Off = 0
                # F2 扫完一圈，进位给 F1
                $F1_Off += $F1步长
                PRINT >>> F2 归零，F1 进位增加 >>>
            ENDIF
        ENDIF
    ENDIF
    
NEXT


FUNC NextSeed
    # 拆 seed
    $hi = $seed >> 16
    $lo = $seed & 65535
    
    # 乘法拆分
    $t1 = $lo * 20077# lo * A_lo
    $t2 = $lo * 16838# lo * A_hi
    $t3 = $hi * 20077# hi * A_lo
    
    # 合并中间项
    $mid = $t2 + $t3
    
    # 组合结果
    $new_lo = $t1 & 65535
    $new_hi = ($mid + ($t1 >> 16)) & 65535
    
    # 加上常数 C
    $new_lo = $new_lo + 24691
    
    IF $new_lo >= 65536
        $new_lo = $new_lo - 65536
        $new_hi = $new_hi + 1
    ENDIF
    
    $new_hi = $new_hi & 65535
    
    # 拼回 32 位
    $seed = ($new_hi << 16) + $new_lo
ENDFUNC
